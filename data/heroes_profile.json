{
  "version": "2.0",
  "schema": "MGTI.heroProfiles.v2",
  "scale": {
    "min": -2,
    "max": 2,
    "neutral": 0,
    "precision": 2,
    "note": "前端 data.js 会读取 heroes 下的 TAC/TEA/EMO/DEC/PRE 数值；本文件保留 version + heroes 结构以兼容旧逻辑。"
  },
  "dimensionRules": {
    "TAC": "正值代表更依赖预判、连招规划、冷却计算、地形控制；负值代表更依赖本能反应、即时换血、肌肉记忆。",
    "TEA": "正值代表强开团、保护、支援、联动能力强；负值代表单带、刺杀、个人线权和孤立作战倾向更强。",
    "EMO": "正值代表更激情、更容易连续进攻或上头；负值代表更冷静、更擅长逆风运营和等待资源。",
    "DEC": "正值代表机会出现时快速出手；负值代表需要铺垫、蹲伏、等技能和队友到位。",
    "PRE": "正值代表高操作、高风险、高回报或非传统英雄偏好；负值代表稳定、传统、安全输出或保护型英雄偏好。"
  },
  "calibrationNotes": {
    "method": "以英雄常见玩法、技能释放结构、团战职责和玩家行为感受为基础进行人工校准，再加入小幅稳定扰动以减少同类英雄聚类。",
    "compatibility": "每个英雄对象只包含五个数值字段；现有 normalizeDimensionObject 会直接读取并限制在 -2 到 +2。",
    "heroCount": 172,
    "duplicateVectorPolicy": "已检测完全相同的五维向量，并用 0.01 级别微调避免重复。"
  },
